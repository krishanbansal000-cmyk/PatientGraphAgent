GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
HEALTHCARE_DATASET=your-healthcare-dataset
HEALTHCARE_FHIR_STORE=your-fhir-store
DEFAULT_PATIENT_ID=your-synthetic-patient-id

# Optional Graphiti semantic memory and FHIR provenance bridge
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=your-neo4j-username
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j
MEDGRAPHITI_ENABLED=false
MEDGRAPHITI_MAX_COROUTINES=2

# Prototype-only shared-password authentication
DEMO_PASSWORD=change-me
DEMO_SESSION_TOKEN=change-me-to-a-long-random-value
DEMO_COOKIE_SECURE=false
